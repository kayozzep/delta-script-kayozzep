    -- =====================================
    -- FUNKTIONEN
    -- =====================================
    
    -- 1️⃣ ANTI-VOICE-BAN (wie Novoline)
    local function antiVoiceBan()
        -- Verhindert das Stummschalten durch den Server
        local voiceService = game:GetService("VoiceChatService")
        if voiceService then
            pcall(function()
                -- Simuliere aktive Sprachaktivität
                spawn(function()
                    while wait(0.1) do
                        pcall(function()
                            voiceService:NotifySpeakingStatus(true)
                        end)
                    end
                end)
            end)
        end
        
        -- Blockiere Voice-Ban-Requests
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            
            if method == "Kick" or method == "Ban" then
                local argStr = tostring(args[1] or "")
                if string.find(argStr:lower(), "voice") or string.find(argStr:lower(), "mic") then
                    return nil -- Blockiere den Ban
                end
            end
            
            return oldNamecall(self, ...)
        end)
        
        print("✅ Anti-Voice-Ban aktiviert!")
        
        -- GUI-Button visuell bestätigen
        local confirm = Instance.new("TextLabel")
        confirm.Size = UDim2.new(0, 200, 0, 30)
        confirm.Position = UDim2.new(0.5, -100, 0.1, 50)
        confirm.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        confirm.BackgroundTransparency = 0.3
        confirm.Text = "✅ Voice-Ban Schutz aktiv!"
        confirm.TextColor3 = Color3.fromRGB(255, 255, 255)
        confirm.TextScaled = true
        confirm.Font = Enum.Font.GothamBold
        confirm.Parent = mainFrame
        
        game:GetService("Debris"):AddItem(confirm, 2)
    end
    
    -- 2️⃣ TELEPORT (zu Spieler oder Position)
    local function teleportTo(target)
        if type(target) == "string" then
            -- Teleport zu Spieler
            for _, plr in pairs(Players:GetPlayers()) do
                if plr.Name:lower():find(target:lower()) then
                    local targetChar = plr.Character
                    if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                        rootPart.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                    end
                end
            end
        elseif type(target) == "Vector3" then
            -- Teleport zu Position
            rootPart.CFrame = CFrame.new(target)
        end
    end
    
    -- 3️⃣ KILL SPIELER
    local function killPlayer(targetName)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(targetName:lower()) then
                local targetChar = plr.Character
                if targetChar then
                    local humanoid = targetChar:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid.Health = 0
                    end
                end
            end
        end
    end
    
    -- 4️⃣ FREEZE / UNFREEZE
    local function toggleFreeze(targetName)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(targetName:lower()) then
                local targetChar = plr.Character
                if targetChar then
                    for _, part in pairs(targetChar:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.Anchored = not part.Anchored
                        end
                    end
                end
            end
        end
    end
    
    -- 5️⃣ FLY MODUS
    local flying = false
    local flySpeed = 50
    local flyBodyVelocity
    
    local function toggleFly()
        flying = not flying
        
        if flying then
            local bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * 10000
            bodyVelocity.Velocity = Vector3.new(0, 10, 0)
            bodyVelocity.Parent = rootPart
            
            flyBodyVelocity = bodyVelocity
            
            -- Steuerung mit WASD/Mobile-Buttons simulieren
            game:GetService("RunService").Heartbeat:Connect(function()
                if flying and rootPart then
                    local moveDirection = Vector3.new(0, 0, 0)
                    
                    -- Hier kannst du mobile Touch-Steuerung einbauen
                    -- Aktuell: Automatisches Schweben
                    flyBodyVelocity.Velocity = Vector3.new(0, 10, 0)
                end
            end)
            
            print("🦅 Flugmodus aktiviert!")
        else
            if flyBodyVelocity then
                flyBodyVelocity:Destroy()
                flyBodyVelocity = nil
            end
            print("🛑 Flugmodus deaktiviert!")
        end
    end
    
    -- 6️⃣ UNBAN ANTI (schützt vor Kicks/Bans)
    local function antiBan()
        local oldKick = game.Kick
        game.Kick = function(...)
            local args = {...}
            for _, arg in pairs(args) do
                if type(arg) == "string" then
                    -- Ersetze Ban-Nachrichten
                    arg = string.gsub(arg, "Ban", "⚠️ Fehler")
                    arg = string.gsub(arg, "Kick", "⚠️ Fehler")
                end
            end
            return false -- Verhindert Kick
        end
        
        -- Hook für RemoteEvents (Anti-Admin-Ban)
        local oldFire = fire
        fire = function(remote, ...)
            if remote.Name:lower():find("ban") or remote.Name:lower():find("kick") then
                return nil -- Blockiere Ban-Requests
            end
            return oldFire(remote, ...)
        end
        
        print("🛡️ Anti-Ban aktiviert!")
    end
    
    -- =====================================
    -- MENÜ BUTTONS ERSTELLEN
