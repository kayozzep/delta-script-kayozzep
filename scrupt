return function()
    local Players = game:GetService("Players")
    local UserInputService = game:GetService("UserInputService")
    local Debris = game:GetService("Debris")
    local Workspace = game:GetService("Workspace")
    
    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart")
    
    -- GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "DeltaAdminMenu"
    screenGui.Parent = player:WaitForChild("PlayerGui")
    
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 350, 0, 500)
    mainFrame.Position = UDim2.new(0.5, -175, 0.5, -250)
    mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    mainFrame.BackgroundTransparency = 0.1
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = screenGui
    mainFrame.Visible = true
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = mainFrame
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 40)
    title.BackgroundTransparency = 1
    title.Text = "⚡ Delta Admin"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = mainFrame
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 40, 0, 40)
    closeBtn.Position = UDim2.new(1, -45, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.TextScaled = true
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.BorderSizePixel = 0
    closeBtn.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = closeBtn
    
    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
    end)
    
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, -20, 1, -60)
    scrollFrame.Position = UDim2.new(0, 10, 0, 50)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 5
    scrollFrame.Parent = mainFrame
    
    local uiList = Instance.new("UIListLayout")
    uiList.SortOrder = Enum.SortOrder.LayoutOrder
    uiList.Padding = UDim.new(0, 8)
    uiList.Parent = scrollFrame
    
    local function createButton(text, color, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 45)
        btn.BackgroundColor3 = color or Color3.fromRGB(45, 45, 60)
        btn.Text = text
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextScaled = true
        btn.Font = Enum.Font.GothamMedium
        btn.BorderSizePixel = 0
        btn.Parent = scrollFrame
        
        local corner2 = Instance.new("UICorner")
        corner2.CornerRadius = UDim.new(0, 8)
        corner2.Parent = btn
        
        btn.MouseButton1Click:Connect(callback)
        return btn
    end
    
    -- Anti-Voice-Ban
    local function antiVoiceBan()
        local voiceService = game:GetService("VoiceChatService")
        if voiceService then
            spawn(function()
                while wait(0.1) do
                    pcall(function()
                        voiceService:NotifySpeakingStatus(true)
                    end)
                end
            end)
        end
        
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            if method == "Kick" or method == "Ban" then
                local argStr = tostring(args[1] or "")
                if string.find(argStr:lower(), "voice") or string.find(argStr:lower(), "mic") then
                    return nil
                end
            end
            return oldNamecall(self, ...)
        end)
        print("✅ Anti-Voice-Ban aktiviert!")
    end
    
    -- Anti-Ban
    local function antiBan()
        local oldKick = game.Kick
        game.Kick = function(...)
            return false
        end
        print("🛡️ Anti-Ban aktiviert!")
    end
    
    -- Teleport
    local function teleportTo(target)
        if not rootPart then return end
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(target:lower()) then
                local targetChar = plr.Character
                if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                    rootPart.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                    print("🌀 Teleportiert zu " .. plr.Name)
                    return
                end
            end
        end
        print("❌ Spieler nicht gefunden!")
    end
    
    -- Kill
    local function killPlayer(targetName)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(targetName:lower()) then
                local targetChar = plr.Character
                if targetChar then
                    local humanoid = targetChar:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid.Health = 0
                        print("💀 " .. plr.Name .. " getötet!")
                        return
                    end
                end
            end
        end
        print("❌ Spieler nicht gefunden!")
    end
    
    -- Freeze
    local function toggleFreeze(targetName)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(targetName:lower()) then
                local targetChar = plr.Character
                if targetChar then
                    for _, part in pairs(targetChar:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.Anchored = not part.Anchored
                        end
                    end
                    print("❄️ " .. plr.Name .. " eingefroren/aufgetaut!")
                    return
                end
            end
        end
        print("❌ Spieler nicht gefunden!")
    end
    
    -- Fly
    local flying = false
    local flyBodyVelocity
    local flyConnection
    
    local function toggleFly()
        if not rootPart then return end
        flying = not flying
        
        if flying then
            local bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * 10000
            bodyVelocity.Velocity = Vector3.new(0, 10, 0)
            bodyVelocity.Parent = rootPart
            flyBodyVelocity = bodyVelocity
            
            flyConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if flying and rootPart and flyBodyVelocity then
                    flyBodyVelocity.Velocity = Vector3.new(0, 10, 0)
                end
            end)
            print("🦅 Flugmodus aktiviert!")
        else
            if flyBodyVelocity then
                flyBodyVelocity:Destroy()
                flyBodyVelocity = nil
            end
            if flyConnection then
                flyConnection:Disconnect()
                flyConnection = nil
            end
            print("🛑 Flugmodus deaktiviert!")
        end
    end
    
    -- Lag-Maschine
    local function lagMachine()
        local folder = Instance.new("Folder")
        folder.Name = "LagFolder"
        folder.Parent = Workspace
        
        for i = 1, 5000 do
            local part = Instance.new("Part")
            part.Size = Vector3.new(1, 1, 1)
            part.Anchored = true
            part.CanCollide = false
            part.Transparency = 0.9
            part.Material = Enum.Material.Neon
            part.CFrame = CFrame.new(
                math.random(-500, 500),
                math.random(-500, 500),
                math.random(-500, 500)
            )
            part.Parent = folder
        end
        print("🐌 5000 Teile erstellt!")
    end
    
    -- Cleanup
    local function cleanup()
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("Part") and obj.Material == Enum.Material.Neon then
                obj:Destroy()
            end
        end
        local folder = Workspace:FindFirstChild("LagFolder")
        if folder then folder:Destroy() end
        print("🧹 Aufgeräumt!")
    end
    
    -- Buttons
    createButton("🔇 Anti-Voice-Ban", Color3.fromRGB(50, 100, 255), antiVoiceBan)
    createButton("🛡️ Anti-Ban", Color3.fromRGB(255, 50, 100), antiBan)
    createButton("🌀 Teleport", Color3.fromRGB(50, 200, 100), function()
        local inputBox = Instance.new("TextBox")
        inputBox.Size = UDim2.new(0, 200, 0, 40)
        inputBox.Position = UDim2.new(0.5, -100, 0.5, -20)
        inputBox.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        inputBox.PlaceholderText = "Spielername"
        inputBox.Font = Enum.Font.Gotham
        inputBox.TextScaled = true
        inputBox.Parent = mainFrame
        inputBox.FocusLost:Connect(function(enterPressed)
            if enterPressed and inputBox.Text ~= "" then
                teleportTo(inputBox.Text)
                inputBox:Destroy()
            end
        end)
        Debris:AddItem(inputBox, 5)
    end)
    
    createButton("💀 Töten", Color3.fromRGB(255, 50, 50), function()
        local inputBox = Instance.new("TextBox")
        inputBox.Size = UDim2.new(0, 200, 0, 40)
        inputBox.Position = UDim2.new(0.5, -100, 0.5, -20)
        inputBox.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        inputBox.PlaceholderText = "Spielername"
        inputBox.Font = Enum.Font.Gotham
        inputBox.TextScaled = true
        inputBox.Parent = mainFrame
        inputBox.FocusLost:Connect(function(enterPressed)
            if enterPressed and inputBox.Text ~= "" then
                killPlayer(inputBox.Text)
                inputBox:Destroy()
            end
        end)
        Debris:AddItem(inputBox, 5)
    end)
    
    createButton("❄️ Freeze", Color3.fromRGB(100, 200, 255), function()
        local inputBox = Instance.new("TextBox")
        inputBox.Size = UDim2.new(0, 200, 0, 40)
        inputBox.Position = UDim2.new(0.5, -100, 0.5, -20)
        inputBox.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        inputBox.PlaceholderText = "Spielername"
        inputBox.Font = Enum.Font.Gotham
        inputBox.TextScaled = true
        inputBox.Parent = mainFrame
        inputBox.FocusLost:Connect(function(enterPressed)
            if enterPressed and inputBox.Text ~= "" then
                toggleFreeze(inputBox.Text)
                inputBox:Destroy()
            end
        end)
        Debris:AddItem(inputBox, 5)
    end)
    
    createButton("🦅 Fly", Color3.fromRGB(255, 200, 50), toggleFly)
    createButton("🐌 Lag", Color3.fromRGB(255, 0, 150), lagMachine)
    createButton("🧹 Cleanup", Color3.fromRGB(100, 100, 100), cleanup)
    
    -- 3-Finger-Tap
    local taps = 0
    local lastTapTime = 0
    
    UserInputService.TouchStarted:Connect(function(touch)
        if touch.Position.X > 50 and touch.Position.Y > 50 then
            local currentTime = tick()
            if currentTime - lastTapTime < 0.5 then
                taps = taps + 1
            else
                taps = 1
            end
            lastTapTime = currentTime
            if taps >= 3 then
                mainFrame.Visible = not mainFrame.Visible
                taps = 0
            end
        end
    end)
    
    print("⚡ Delta Admin geladen! (3-Finger-Tap)")
    antiVoiceBan()
    antiBan()
end