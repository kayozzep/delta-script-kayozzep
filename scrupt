    -- =====================================
    -- MOBILE GESTEN
    -- =====================================
    
    -- Menü mit 3-Finger-Tap öffnen/schließen
    local taps = 0
    local lastTapTime = 0
    
    UserInputService.TouchStarted:Connect(function(touch)
        if touch.Position.X > 50 and touch.Position.Y > 50 then
            local currentTime = tick()
            if currentTime - lastTapTime < 0.5 then
                taps = taps + 1
            else
                taps = 1
            end
            lastTapTime = currentTime
            
            if taps >= 3 then
                -- Menü togglen
                mainFrame.Visible = not mainFrame.Visible
                taps = 0
            end
        end
    end)
    
